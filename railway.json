{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "services": {
    "backend": {
      "build": {
        "dockerfilePath": "Dockerfile.backend",
        "context": "."
      },
      "deploy": {
        "healthcheckPath": "/",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "frontend": {
      "build": {
        "dockerfilePath": "phase5_ui/frontend/Dockerfile",
        "context": "phase5_ui/frontend"
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
